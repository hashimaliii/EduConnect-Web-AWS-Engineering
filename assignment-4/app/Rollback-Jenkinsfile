/**
 * Manual Rollback Pipeline for Blue-Green Deployment
 * Flips the ALB listener back to the previous target group
 */

pipeline {
    agent { label 'linux-agent' }
    
    environment {
        AWS_REGION = 'us-east-1'
        AWS_CREDENTIALS = credentials('aws-creds')
        ALB_LISTENER_ARN = 'arn:aws:elasticloadbalancing:us-east-1:123456789012:listener/app/educonnect-alb/123456/7890' // Need actual ARN or lookup
        TARGET_GROUP_BLUE_ARN = 'arn:aws:elasticloadbalancing:us-east-1:123456789012:targetgroup/blue-web-tg/12345'
        TARGET_GROUP_GREEN_ARN = 'arn:aws:elasticloadbalancing:us-east-1:123456789012:targetgroup/green-web-tg/12345'
    }

    options {
        buildDiscarder(logRotator(numToKeepStr: '5'))
        timeout(time: 10, unit: 'MINUTES')
        timestamps()
    }
    
    stages {
        stage('Determine Current Live') {
            steps {
                script {
                    echo "Checking current live target group..."
                    // Get current default action of the listener
                    def currentTgArn = sh(
                        script: """
                        aws elbv2 describe-listeners \
                            --listener-arns ${ALB_LISTENER_ARN} \
                            --region ${AWS_REGION} \
                            --query 'Listeners[0].DefaultActions[0].TargetGroupArn' \
                            --output text
                        """,
                        returnStdout: true
                    ).trim()
                    
                    env.CURRENT_LIVE_TG = currentTgArn
                    
                    if (currentTgArn.contains('blue')) {
                        env.NEW_LIVE_TG = TARGET_GROUP_GREEN_ARN
                        env.NEW_COLOR = "green"
                        env.OLD_COLOR = "blue"
                    } else if (currentTgArn.contains('green')) {
                        env.NEW_LIVE_TG = TARGET_GROUP_BLUE_ARN
                        env.NEW_COLOR = "blue"
                        env.OLD_COLOR = "green"
                    } else {
                        error "Could not determine current live target group."
                    }
                    
                    echo "Current Live: ${env.OLD_COLOR} | Rolling back to: ${env.NEW_COLOR}"
                }
            }
        }
        
        stage('Rollback Traffic') {
            steps {
                echo "Flipping traffic back to ${env.NEW_COLOR}..."
                sh """
                aws elbv2 modify-listener \
                    --listener-arn ${ALB_LISTENER_ARN} \
                    --default-actions Type=forward,TargetGroupArn=${NEW_LIVE_TG} \
                    --region ${AWS_REGION}
                """
                echo "Rollback successful!"
            }
        }
        
        stage('Log Rollback') {
            steps {
                script {
                    def logEntry = """{"timestamp":"${java.time.Instant.now()}","action":"rollback","previous_color":"${env.OLD_COLOR}","new_color":"${env.NEW_COLOR}","result":"success"}"""
                    sh """
                    echo '${logEntry}' >> rollback-log.jsonl
                    # aws s3 cp rollback-log.jsonl s3://your-deployment-logs-bucket/rollback-logs.jsonl
                    """
                }
            }
        }
    }
    
    post {
        always {
            cleanWs()
        }
    }
}
